<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/passwordRootLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/background"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/password_constraintLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        android:foreground="?attr/selectableItemBackground"
        android:padding="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/password_passwordIcon_imageView"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:background="@drawable/shimmer_loading_effect"
            app:layout_constraintBottom_toBottomOf="@+id/password_passwordInfo_textView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="ContentDescription,ImageContrastCheck" />

        <TextView
            android:id="@+id/password_passwordTitle_textView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text=""
            android:textColor="#2a2a2a"
            android:textSize="20sp"
            app:layout_constraintEnd_toStartOf="@+id/password_options_imageView"
            app:layout_constraintStart_toEndOf="@+id/password_passwordIcon_imageView"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/password_options_imageView"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_options"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#838d95"
            tools:ignore="ContentDescription" />

        <TextView
            android:id="@+id/password_passwordInfo_textView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/shimmer_loading_effect"
            android:text=""
            android:textColor="#838d95"
            android:textSize="16sp"
            app:layout_constraintEnd_toStartOf="@+id/password_options_imageView"
            app:layout_constraintStart_toStartOf="@+id/password_passwordTitle_textView"
            app:layout_constraintTop_toBottomOf="@+id/password_passwordTitle_textView" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>


